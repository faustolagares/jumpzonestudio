---
import AstroHomeApp from '../AstroHomeApp';
import '../../index.css';

const title = 'Jump Zone Studio | New Fitness Experience in Newark, NJ';
const description = 'Discover Jump Zone Studio, a new high-energy trampoline fitness experience in Newark, NJ. Book your jump, view schedules, memberships, and contact the studio.';
const heroImage = 'https://imagedelivery.net/O1Es2ZMHV0HF7g71pX5Prg/1d011d00-e9e8-4d0f-7cd3-35886e138100/public';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#050505" />
    <meta property="og:site_name" content="Jump Zone Studio" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://jumpzonestudio.com/astro" />
    <meta property="og:image" content={heroImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={heroImage} />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="shortcut icon" href="https://imagedelivery.net/O1Es2ZMHV0HF7g71pX5Prg/9cb12b7f-5233-40fe-7c31-7e6720039700/public" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <link rel="canonical" href="https://jumpzonestudio.com/astro" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://imagedelivery.net" crossorigin />
    <link rel="preload" as="image" href={heroImage} fetchpriority="high" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Teko:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />
  </head>
  <body class="bg-[#050505]">
    <AstroHomeApp initialLanguage="en" />
    <div id="astro-mobile-menu" class="fixed inset-0 z-[90] hidden flex-col bg-deep-black text-white md:hidden">
      <div class="flex items-center justify-between px-5 pb-4 pt-5">
        <a href="/astro" aria-label="Jump Zone Studio home" class="relative h-14 w-36">
          <img
            src="https://imagedelivery.net/O1Es2ZMHV0HF7g71pX5Prg/b0ec63bd-b95c-4893-0999-5ab3d9ca4500/public"
            alt="Jump Zone Studio"
            class="absolute left-0 top-[60%] h-20 w-auto -translate-y-1/2 object-contain"
            decoding="async"
          />
        </a>
        <button
          id="astro-menu-close"
          type="button"
          aria-label="Close menu"
          class="relative grid h-[42px] w-[42px] place-items-center border border-white/10 bg-[#111]"
          style="clip-path: polygon(6px 0%, calc(100% - 6px) 0%, 100% 6px, 100% calc(100% - 6px), calc(100% - 6px) 100%, 6px 100%, 0% calc(100% - 6px), 0% 6px);"
        >
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18" />
            <path d="m6 6 12 12" />
          </svg>
        </button>
      </div>
      <div class="flex flex-1 flex-col items-center justify-center gap-1 px-6">
        <button type="button" data-astro-menu-link="classes" class="block w-full py-3 text-center font-display text-4xl font-black uppercase italic leading-none tracking-tight text-white">CLASSES</button>
        <button type="button" data-astro-menu-link="classes" class="block w-full py-3 text-center font-display text-4xl font-black uppercase italic leading-none tracking-tight text-white">SCHEDULE</button>
        <button type="button" data-astro-menu-link="pricing" class="block w-full py-3 text-center font-display text-4xl font-black uppercase italic leading-none tracking-tight text-white">PRICING</button>
        <button type="button" data-astro-menu-link="studio" class="block w-full py-3 text-center font-display text-4xl font-black uppercase italic leading-none tracking-tight text-white">THE STUDIO</button>
        <button type="button" data-astro-menu-link="footer" class="block w-full py-3 text-center font-display text-4xl font-black uppercase italic leading-none tracking-tight text-white">CONTACT</button>
      </div>
      <div class="px-6 pt-6" style="padding-bottom: max(2rem, env(safe-area-inset-bottom) + 1.5rem);">
        <a
          href="/bio"
          class="relative flex min-h-14 w-full items-center justify-between bg-energy-green px-7 py-4 font-sans text-[13px] font-black uppercase italic leading-none tracking-wider text-deep-black"
          style="clip-path: polygon(10px 0%, 100% 0%, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0% 100%, 0% 10px);"
        >
          <span class="text-deep-black/30">//</span>
          <span>BOOK NOW</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
    <script is:inline>
      (() => {
        const menu = document.getElementById('astro-mobile-menu');
        const openButton = document.querySelector('button[aria-label="Open menu"]');
        const closeButton = document.getElementById('astro-menu-close');
        const setOpen = (open) => {
          if (!menu) return;
          menu.classList.toggle('hidden', !open);
          menu.classList.toggle('flex', open);
          document.body.style.overflow = open ? 'hidden' : '';
        };

        openButton?.addEventListener('click', () => setOpen(true));
        closeButton?.addEventListener('click', () => setOpen(false));
        document.querySelectorAll('[data-astro-menu-link]').forEach((button) => {
          button.addEventListener('click', () => {
            setOpen(false);
            const target = document.getElementById(button.getAttribute('data-astro-menu-link') || '');
            if (target) {
              window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
            }
          });
        });
      })();
    </script>
  </body>
</html>
